# All optional — the app runs fine with none of these set.

# Enables Claude deal scoring (1-10 + one-line verdict per deal)
ANTHROPIC_API_KEY=

# Override the Claude model used for scoring
DEALRADAR_AI_MODEL=claude-opus-4-8

# Background feed-refresh interval in minutes (default 15)
DEALRADAR_REFRESH_MINUTES=15

# Enables the "→ Discord" button (posts top deals to your channel)
DISCORD_WEBHOOK_URL=

# Server port (default 8000)
PORT=8000

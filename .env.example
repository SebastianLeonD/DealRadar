ODDS_API_KEY=your_the_odds_api_key_here
# Active sport: nba or world_cup
ACTIVE_SPORT=world_cup
# Optional: trim books or disable alternates to save Odds-API credits
SHARP_BOOKMAKERS=draftkings,fanduel,betmgm,williamhill_us
INCLUDE_ALTERNATE_LINES=1
# Optional: only fetch odds for games starting within this many hours
# MAX_HOURS_AHEAD=36

# --- AI Analyst (the "Ask AI" button) ---
# Backend: auto (default) | cli | sdk
#   cli  = the logged-in `claude` CLI, runs on your Claude Pro/Max subscription
#          (no metered API key). auto uses it when installed.
#   sdk  = the metered Anthropic API; requires ANTHROPIC_API_KEY below.
# AI_BACKEND=auto
# AI_CLI_MODEL=opus
# ANTHROPIC_API_KEY=your_anthropic_api_key_here   # only needed for AI_BACKEND=sdk
